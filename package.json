
{
  "name": "vj-studio",
  "version": "2.0.0",
  "productName": "VJ STUDIO",
  "description": "VJ STUDIO — HYPER EDITION v2",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.vjstudio.hyperapp",
    "productName": "VJ STUDIO",
    "files": [
      "index.html",
      "main.js",
      "preload.js",
      "three.min.js"
    ],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "requestedExecutionLevel": "asInvoker",
      "publish": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "VJ STUDIO"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
